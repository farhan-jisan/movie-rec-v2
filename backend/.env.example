# Copy this file to `.env` and fill in real values for local development.
# On Render, these become Secret Files / Environment Variables in the dashboard.

# TMDB v3 API key — required. Get one at https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_v3_api_key_here

# Comma-separated list of allowed CORS origins.
# Local dev defaults to Vite at :5173; production should list the Vercel domain.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional: path to the artifacts directory. Defaults to app/data/artifacts/.
ARTIFACTS_DIR=